<UserControl x:Class="DASD.Views.MediaLibPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="Page_IsVisibleChanged">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Click="BackButton_Click" Content="← 返回"
                    Visibility="Collapsed" Margin="0,0,8,0" />
            <TextBlock x:Name="CountLabel" Grid.Column="1" VerticalAlignment="Center"
                       Style="{StaticResource CaptionText}" Margin="0,0,12,0" />
            <TextBox x:Name="SearchBox" Grid.Column="2" MaxWidth="320" HorizontalAlignment="Left"
                     MinWidth="220" TextChanged="SearchBox_TextChanged" />
            <Button x:Name="GenreButton" Grid.Column="3" Margin="8,0,0,0"
                    Click="GenreButton_Click" Content="作品标签" />
            <Button x:Name="OpenFolderButton" Grid.Column="4" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="OpenFolderButton_Click" Content="打开文件夹" />
            <Button x:Name="ViewFilesButton" Grid.Column="5" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="ViewFilesButton_Click" Content="查看作品" />
            <Button x:Name="MoveLibButton" Grid.Column="6" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="MoveLibButton_Click" Content="移动媒体库" />
            <Button x:Name="LibSettingButton" Grid.Column="7" Margin="8,0,0,0"
                    Click="LibSettingButton_Click" Content="媒体库设置" />
        </Grid>

        <!-- 卡片区 / 详情区 -->
        <ScrollViewer x:Name="CardsScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      ScrollChanged="CardsScroll_ScrollChanged">
            <ContentPresenter x:Name="ContentHost" />
        </ScrollViewer>
    </Grid>
</UserControl>
