<UserControl x:Class="DASD.Views.MediaLibPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="Page_IsVisibleChanged">
    <UserControl.Resources>
        <!-- 整页预览左右切换的半透明圆形箭头按钮 -->
        <Style x:Key="PreviewArrowButton" TargetType="Button">
            <Setter Property="Width" Value="56" />
            <Setter Property="Height" Value="56" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="30" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#66000000" CornerRadius="28">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#AA000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶栏 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SearchBox" Grid.Column="0" MaxWidth="320" HorizontalAlignment="Left"
                     MinWidth="220" TextChanged="SearchBox_TextChanged" />
            <ComboBox x:Name="SortBox" Grid.Column="1" Margin="8,0,0,0" MinWidth="130" Visibility="Collapsed"
                      VerticalAlignment="Center" SelectionChanged="SortBox_SelectionChanged" />
            <Button x:Name="LibToggleButton" Grid.Column="2" Margin="8,0,0,0" Visibility="Collapsed"
                    VerticalAlignment="Center" Click="LibToggleButton_Click" Content="显示社团" />
            <TextBlock x:Name="RjLabel" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left"
                       Margin="0,0,8,0" FontWeight="SemiBold" Visibility="Collapsed" />
            <Button x:Name="OpenFolderButton" Grid.Column="4" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="OpenFolderButton_Click" Content="打开文件夹" />
            <Button x:Name="ViewFilesButton" Grid.Column="5" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="ViewFilesButton_Click" Content="查看作品" />
            <Button x:Name="MoveLibButton" Grid.Column="6" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="MoveLibButton_Click" Content="移动媒体库" />
            <Button x:Name="ReadButton" Grid.Column="7" Margin="8,0,0,0" Visibility="Collapsed"
                    FontFamily="Segoe UI Emoji" Click="ReadButton_Click" Content="☆ 已读" />
            <Button x:Name="FavButton" Grid.Column="8" Margin="8,0,0,0" Visibility="Collapsed"
                    FontFamily="Segoe UI Emoji" Click="FavButton_Click" Content="🤍 收藏" />
            <Button x:Name="LibSettingButton" Grid.Column="9" Margin="8,0,0,0" Visibility="Collapsed"
                    Click="LibSettingButton_Click" Content="媒体库设置" />
            <TextBlock x:Name="CountLabel" Grid.Column="10" VerticalAlignment="Center"
                       Style="{StaticResource CaptionText}" Margin="12,0,12,0" />
            <Button x:Name="BackButton" Grid.Column="11" Click="BackButton_Click" Content="← 返回"
                    Visibility="Collapsed" />
        </Grid>

        <!-- 卡片区 / 详情区 -->
        <ScrollViewer x:Name="CardsScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      ScrollChanged="CardsScroll_ScrollChanged">
            <ContentPresenter x:Name="ContentHost" />
        </ScrollViewer>

        <!-- 底部音频播放条由代码动态加入 RootGrid 第 2 行（避免 XAML 引用本程序集类型触发临时程序集编译） -->

        <!-- 整页预览覆盖层（图片/视频），盖住顶栏与详情区 -->
        <Grid x:Name="PreviewOverlay" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed"
              Background="{StaticResource WindowBrush}" Focusable="True"
              KeyDown="PreviewOverlay_KeyDown">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="PreviewCloseButton" Click="PreviewClose_Click" Content="← 返回" />
                <TextBlock x:Name="PreviewTitle" Grid.Column="1" VerticalAlignment="Center"
                           Margin="12,0" TextTrimming="CharacterEllipsis" />
                <StackPanel x:Name="PreviewNavBar" Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="PreviewPrevButton" Click="PreviewPrev_Click" Content="‹ 上一张" />
                    <Button x:Name="PreviewNextButton" Click="PreviewNext_Click" Content="下一张 ›"
                            Margin="8,0,0,0" />
                </StackPanel>
            </Grid>
            <Border x:Name="PreviewContent" Grid.Row="1" Background="#111111" CornerRadius="4" />
            <!-- 图片左右切换箭头：覆盖在预览图两侧、垂直居中 -->
            <Button x:Name="PreviewPrevArrow" Grid.Row="1" Style="{StaticResource PreviewArrowButton}"
                    HorizontalAlignment="Left" Margin="20,0,0,0" Content="‹"
                    Click="PreviewPrev_Click" Visibility="Collapsed" />
            <Button x:Name="PreviewNextArrow" Grid.Row="1" Style="{StaticResource PreviewArrowButton}"
                    HorizontalAlignment="Right" Margin="0,0,20,0" Content="›"
                    Click="PreviewNext_Click" Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
