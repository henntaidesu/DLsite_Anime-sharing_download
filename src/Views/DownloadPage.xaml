<UserControl x:Class="DASD.Views.DownloadPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:DASD.Views"
             IsVisibleChanged="Page_IsVisibleChanged">
    <UserControl.Resources>
        <!-- 目录树展开/收起小三角（文件夹节点用） -->
        <Style x:Key="ExpandToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource CaptionBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Content" Value="▸" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Content" Value="▾" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 文件叶子节点（按类型隐式套用：目录树里出现 DownloadFileItem 即用此模板） -->
        <DataTemplate DataType="{x:Type v:DownloadFileItem}">
            <StackPanel Margin="0,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="130" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding FileName}"
                               Foreground="{StaticResource CaptionBrush}"
                               ToolTip="{Binding Url}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <ProgressBar Grid.Column="1" Value="{Binding Pct}" Maximum="100"
                                 Height="10" VerticalAlignment="Center"
                                 Margin="0,0,12,0"
                                 Foreground="#39507e" Background="#1c2130" />
                    <TextBlock Grid.Column="2" Text="{Binding SpeedText}"
                               Style="{StaticResource CaptionText}"
                               VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding StatusText}"
                               Foreground="{Binding StatusBrush}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="4" Content="{Binding CopyUrlText}"
                            FontSize="11" Padding="8,2" Margin="8,0,0,0"
                            Click="CopyUrl_Click" />
                </Grid>
                <TextBlock Text="{Binding ErrorReason}"
                           Visibility="{Binding ErrorVisibility}"
                           Foreground="#f87171" FontSize="11"
                           TextWrapping="Wrap" Margin="0,3,0,0" />
            </StackPanel>
        </DataTemplate>

        <!-- 文件夹节点：标题行 + 递归子节点（子节点按类型隐式套用上面的文件/文件夹模板） -->
        <DataTemplate DataType="{x:Type v:DownloadFolderItem}">
            <StackPanel Margin="0,2,0,0">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton IsChecked="{Binding IsExpanded}" Style="{StaticResource ExpandToggle}" />
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               VerticalAlignment="Center" Margin="2,0,0,0" />
                </StackPanel>
                <ItemsControl ItemsSource="{Binding Children}" Visibility="{Binding ChildrenVisibility}"
                              Margin="16,0,0,0" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶栏：开始/刷新/清理 + 用量 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>
            <Button x:Name="SearchWorkButton" Style="{StaticResource AccentButton}" MinWidth="100"
                    Click="SearchWorkButton_Click" Content="搜索作品" />
            <Button x:Name="StartButton" Grid.Column="1" Margin="8,0,0,0" MinWidth="100"
                    Click="StartButton_Click" Content="开始下载" />
            <Button x:Name="RefreshButton" Grid.Column="2" Margin="8,0,0,0"
                    Click="RefreshButton_Click" Content="刷新" />
            <Button x:Name="ClearDoneButton" Grid.Column="3" Margin="8,0,0,0"
                    Click="ClearDoneButton_Click" Content="清除已完成" />
            <Button x:Name="ClearAllButton" Grid.Column="4" Margin="8,0,0,0"
                    Click="ClearAllButton_Click" Content="清空列表" />
            <Button x:Name="ShowDownloadedButton" Grid.Column="5" Margin="8,0,0,0"
                    Click="ShowDownloadedButton_Click" Content="已下载" />
            <TextBlock x:Name="UsageLabel" Grid.Column="7" VerticalAlignment="Center"
                       Style="{StaticResource CaptionText}" Margin="0,0,8,0" Text="debrid-link 使用量 --" />
            <ProgressBar x:Name="UsageBar" Grid.Column="8" Height="10" VerticalAlignment="Center" />
        </Grid>

        <!-- 下载列表（两级树：番号 -> 分卷文件） -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GroupList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource Card}" Margin="0,3">
                            <StackPanel>
                                <!-- 父行：番号 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton IsChecked="{Binding IsExpanded}" Width="20" Height="20"
                                                  Background="Transparent" BorderThickness="0"
                                                  Foreground="{StaticResource CaptionBrush}"
                                                  Cursor="Hand">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Content" Value="▸" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center" />
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="Content" Value="▾" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <TextBlock Grid.Column="1" Text="{Binding WorkId}" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <ProgressBar Value="{Binding Pct}" Maximum="100" Height="18" />
                                        <TextBlock Text="{Binding PctText}" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>
                                    <TextBlock Grid.Column="3" Text="{Binding SpeedText}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding StatusText}"
                                               Foreground="{Binding StatusBrush}" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="5" Orientation="Horizontal">
                                        <Button Content="{Binding DownloadText}" FontSize="12" Padding="10,3"
                                                Visibility="{Binding ResumeVisibility}" Click="DownloadOne_Click" />
                                        <Button Content="{Binding StopText}" FontSize="12" Padding="10,3"
                                                Margin="6,0,0,0" Visibility="{Binding PauseVisibility}"
                                                Click="StopOne_Click" />
                                        <Button Content="{Binding ReparseText}" FontSize="12" Padding="10,3"
                                                Margin="6,0,0,0" Visibility="{Binding ActionsVisibility}"
                                                Click="Reparse_Click" />
                                        <Button Content="{Binding ResearchText}" FontSize="12" Padding="10,3"
                                                Style="{StaticResource WarnButton}"
                                                Margin="6,0,0,0" Visibility="{Binding ActionsVisibility}"
                                                Click="Research_Click" />
                                        <Button Content="{Binding DeleteText}" FontSize="12" Padding="10,3"
                                                Style="{StaticResource DangerButton}"
                                                Margin="6,0,0,0" Click="DeleteOne_Click" />
                                    </StackPanel>
                                </Grid>
                                <!-- 子树：作品内目录层级（文件夹/文件递归），最多约 10 行高，超出滚动 -->
                                <ScrollViewer Visibility="{Binding ChildrenVisibility}" Margin="24,4,0,0"
                                              MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Nodes}" />
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
