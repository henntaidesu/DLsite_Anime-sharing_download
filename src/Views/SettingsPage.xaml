<UserControl x:Class="DASD.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="Page_IsVisibleChanged">
    <UserControl.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock"
               BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="120" />
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Stretch" MaxWidth="1100" Margin="0,0,8,0">

            <!-- 下载 -->
            <GroupBox x:Name="DownloadGroup" Header="下载">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock x:Name="PathLabel" Text="缓存路径" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" />
                        <Button x:Name="PathChooseButton" Content="保存" Margin="8,0,0,0" DockPanel.Dock="Right"
                                Click="PathChooseButton_Click" />
                        <TextBox x:Name="PathBox" LostFocus="PathBox_LostFocus" />
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock x:Name="AutoDownloadLabel" Text="自动下载" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="AutoDownloadCombo" Width="120"
                                  SelectionChanged="AutoDownloadCombo_SelectionChanged" />
                        <TextBlock x:Name="AutoUnzipLabel" Text="自动解压" Style="{StaticResource FieldLabel}"
                                   MinWidth="0" Margin="24,0,12,0" />
                        <ComboBox x:Name="AutoUnzipCombo" Width="120"
                                  SelectionChanged="AutoUnzipCombo_SelectionChanged" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- 代理 -->
            <GroupBox x:Name="ProxyGroup" Header="代理">
                <StackPanel>
                    <DockPanel Margin="0,4">
                        <TextBlock x:Name="ProxyStatusLabel" Text="开启" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" />
                        <ComboBox x:Name="ProxyStatusCombo" Width="120" DockPanel.Dock="Left"
                                  SelectionChanged="ProxyStatusCombo_SelectionChanged" />
                        <ComboBox x:Name="ProxyTypeCombo" Width="100" Margin="8,0,0,0" DockPanel.Dock="Left"
                                  SelectionChanged="ProxyTypeCombo_SelectionChanged" />
                        <TextBox x:Name="ProxyPortBox" Width="80" Margin="8,0,0,0" DockPanel.Dock="Right"
                                 LostFocus="Proxy_LostFocus" />
                        <TextBox x:Name="ProxyHostBox" Margin="8,0,0,0"
                                 LostFocus="Proxy_LostFocus" />
                    </DockPanel>
                </StackPanel>
            </GroupBox>

            <!-- Debrid-Link -->
            <GroupBox x:Name="DebridGroup" Header="Debrid-Link 下载中转站">
                <DockPanel Margin="0,4">
                    <TextBlock Text="API Key" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left" />
                    <Button x:Name="DebridTestButton" Content="测试" Margin="8,0,0,0" DockPanel.Dock="Right"
                            Click="DebridTestButton_Click" />
                    <TextBox x:Name="DebridKeyBox" LostFocus="DebridKeyBox_LostFocus" />
                </DockPanel>
            </GroupBox>

            <!-- 作品类型优先搜索 -->
            <GroupBox x:Name="SearchSourceGroup" Header="作品类型优先搜索">
                <StackPanel>
                    <!-- 每个已知作品类型一行（动态生成）：类型名（代码）+ 来源下拉 -->
                    <WrapPanel x:Name="SearchSourcePanel" />
                    <TextBlock x:Name="SearchSourceHint" Text="未列出的作品类型归为「其他」，仅使用 anime-sharing"
                               Style="{StaticResource CaptionText}" Margin="0,6,0,0" />
                </StackPanel>
            </GroupBox>

            <!-- ASMR.ONE -->
            <GroupBox x:Name="AsmrGroup" Header="ASMR.ONE">
                <StackPanel>
                    <!-- 账号 + 密码 同一行 -->
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock x:Name="AsmrUserLabel" Text="账号" Style="{StaticResource FieldLabel}" />
                        <TextBox x:Name="AsmrUserBox" Width="280" VerticalContentAlignment="Center"
                                 LostFocus="AsmrUserBox_LostFocus" />
                        <TextBlock x:Name="AsmrPassLabel" Text="密码" Style="{StaticResource FieldLabel}"
                                   MinWidth="0" Margin="24,0,12,0" />
                        <TextBox x:Name="AsmrPassBox" Width="280" VerticalContentAlignment="Center"
                                 LostFocus="AsmrPassBox_LostFocus" />
                        <Button x:Name="AsmrTestButton" Content="登录测试" Margin="16,0,0,0"
                                Click="AsmrTestButton_Click" />
                    </StackPanel>
                    <!-- 镜像站 + 下载文件类型（两行）同一行 -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock x:Name="AsmrMirrorLabel" Text="镜像站" Style="{StaticResource FieldLabel}"
                                   VerticalAlignment="Top" />
                        <ComboBox x:Name="AsmrMirrorCombo" Width="160" VerticalAlignment="Top"
                                  SelectionChanged="AsmrMirrorCombo_SelectionChanged" />
                        <TextBlock x:Name="AsmrFileTypeLabel" Text="下载文件类型" Style="{StaticResource FieldLabel}"
                                   MinWidth="0" Margin="24,0,12,0" VerticalAlignment="Top" />
                        <WrapPanel x:Name="FileTypePanel" MaxWidth="400" VerticalAlignment="Top" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- 下载选项 -->
            <GroupBox x:Name="OtherGroup" Header="下载选项">
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock x:Name="DownProcLabel" Text="单文件线程数" Style="{StaticResource FieldLabel}" />
                    <TextBox x:Name="DownProcBox" Width="80" LostFocus="DownProcBox_LostFocus" />
                    <TextBlock x:Name="MinSpeedLabel" Text="最低速度 (KB/s)" Style="{StaticResource FieldLabel}"
                               MinWidth="0" Margin="24,0,12,0" />
                    <TextBox x:Name="MinSpeedBox" Width="80" LostFocus="MinSpeedBox_LostFocus" />
                    <TextBlock x:Name="SpeedLimitLabel" Text="速度限制 (KB/s)" Style="{StaticResource FieldLabel}"
                               MinWidth="0" Margin="24,0,12,0" />
                    <TextBox x:Name="SpeedLimitBox" Width="80" LostFocus="SpeedLimitBox_LostFocus" />
                </StackPanel>
            </GroupBox>

            <!-- 外部访问 -->
            <GroupBox x:Name="WebGroup" Header="外部访问">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock x:Name="WebEnableLabel" Text="外部访问" Style="{StaticResource FieldLabel}" />
                        <ComboBox x:Name="WebEnableCombo" Width="120"
                                  SelectionChanged="WebEnableCombo_SelectionChanged" />
                        <TextBlock x:Name="WebPortLabel" Text="端口" Style="{StaticResource FieldLabel}"
                                   MinWidth="0" Margin="24,0,12,0" />
                        <TextBox x:Name="WebPortBox" Width="90" LostFocus="WebPortBox_LostFocus" />
                        <TextBlock x:Name="WebPasswordLabel" Text="访问密码" Style="{StaticResource FieldLabel}"
                                   MinWidth="0" Margin="24,0,12,0" />
                        <TextBox x:Name="WebPasswordBox" Width="160" LostFocus="WebPasswordBox_LostFocus" />
                    </StackPanel>
                    <TextBlock x:Name="WebStatusLabel" Margin="0,6,0,0"
                               Foreground="{StaticResource CaptionBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </GroupBox>

            <!-- 系统 -->
            <GroupBox x:Name="SystemGroup" Header="系统">
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock x:Name="LanguageLabel" Text="语言" Style="{StaticResource FieldLabel}" />
                    <ComboBox x:Name="LanguageCombo" Width="140"
                              SelectionChanged="LanguageCombo_SelectionChanged" />
                    <TextBlock x:Name="LogLevelLabel" Text="日志级别" Style="{StaticResource FieldLabel}"
                               MinWidth="0" Margin="24,0,12,0" />
                    <ComboBox x:Name="LogLevelCombo" Width="120"
                              SelectionChanged="LogLevelCombo_SelectionChanged" />
                    <TextBlock x:Name="EncodingLabel" Text="解压编码" Style="{StaticResource FieldLabel}"
                               MinWidth="0" Margin="24,0,12,0" />
                    <TextBox x:Name="EncodingBox" Width="120" LostFocus="EncodingBox_LostFocus" />
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</UserControl>
