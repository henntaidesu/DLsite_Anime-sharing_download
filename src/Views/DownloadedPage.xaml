<UserControl x:Class="DASD.Views.DownloadedPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsVisibleChanged="Page_IsVisibleChanged">
    <UserControl.Resources>
        <!-- 过长文本显示省略号，悬停时用气泡展示全文 -->
        <Style x:Key="EllipsisCell" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}" />
            <Style.Triggers>
                <Trigger Property="Text" Value="">
                    <Setter Property="ToolTip" Value="{x:Null}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <!-- 可点击排序的表头 -->
        <Style x:Key="HeaderCell" TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- 行卡片（与下载页的 Card 一致） -->
        <Style x:Key="RowCard" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,3" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="border" Background="{StaticResource CardBrush}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2a3040" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{StaticResource ButtonHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶栏：搜索框居左，刷新按钮居右 -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Click="BackButton_Click" Content="← 下载" Margin="0,0,8,0" />
            <TextBox x:Name="SearchBox" Grid.Column="1" MinWidth="220" MaxWidth="320"
                     VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged" />
            <ComboBox x:Name="StateFilter" Grid.Column="2" Margin="8,0,0,0" MinWidth="110"
                      SelectionChanged="StateFilter_SelectionChanged" />
            <TextBlock x:Name="CountLabel" Grid.Column="4" VerticalAlignment="Center"
                       Margin="0,0,12,0" Style="{StaticResource CaptionText}" />
            <Button x:Name="RefreshButton" Grid.Column="5" Click="RefreshButton_Click" Content="刷新" />
        </Grid>

        <!-- 表头：点击切换排序（与行卡片同列宽，左右留出卡片内边距） -->
        <Grid Grid.Row="1" Margin="14,0,24,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="130" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="160" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="HdrId" Style="{StaticResource HeaderCell}"
                       Tag="WorkId" MouseLeftButtonUp="Header_Click" />
            <TextBlock x:Name="HdrName" Grid.Column="1" Margin="0,0,12,0" Style="{StaticResource HeaderCell}"
                       Tag="WorkName" MouseLeftButtonUp="Header_Click" />
            <TextBlock x:Name="HdrMaker" Grid.Column="2" Margin="0,0,12,0" Style="{StaticResource HeaderCell}"
                       Tag="MakerName" MouseLeftButtonUp="Header_Click" />
            <TextBlock x:Name="HdrType" Grid.Column="3" Margin="0,0,12,0" Style="{StaticResource HeaderCell}"
                       Tag="WorkType" MouseLeftButtonUp="Header_Click" />
            <TextBlock x:Name="HdrState" Grid.Column="4" Style="{StaticResource HeaderCell}"
                       Tag="StateText" MouseLeftButtonUp="Header_Click" />
            <TextBlock x:Name="HdrTime" Grid.Column="5" Style="{StaticResource HeaderCell}"
                       Tag="DownTime" MouseLeftButtonUp="Header_Click" />
        </Grid>

        <!-- 列表：每行一张卡片（与下载页风格一致） -->
        <ListBox x:Name="WorksList" Grid.Row="2" Background="Transparent" BorderThickness="0"
                 ItemContainerStyle="{StaticResource RowCard}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 ScrollViewer.ScrollChanged="WorksList_ScrollChanged"
                 PreviewMouseRightButtonDown="WorksList_PreviewMouseRightButtonDown"
                 ContextMenuOpening="WorksList_ContextMenuOpening">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding WorkId}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding WorkName}" Margin="0,0,12,0"
                                   Style="{StaticResource EllipsisCell}" />
                        <TextBlock Grid.Column="2" Text="{Binding MakerName}" Margin="0,0,12,0"
                                   Foreground="{StaticResource CaptionBrush}"
                                   Style="{StaticResource EllipsisCell}" />
                        <TextBlock Grid.Column="3" Text="{Binding WorkType}" Margin="0,0,12,0"
                                   Foreground="{StaticResource CaptionBrush}"
                                   Style="{StaticResource EllipsisCell}" />
                        <TextBlock Grid.Column="4" Text="{Binding StateText}" Foreground="{Binding StateBrush}"
                                   FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding DownTime}"
                                   Foreground="{StaticResource CaptionBrush}" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="MarkMenuItem" Header="标记为已品悦" Click="MarkEnjoyed_Click" />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </Grid>
</UserControl>
