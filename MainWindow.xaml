<Window x:Class="DASD.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DLsite 下载器" Height="760" Width="1280"
        Background="{StaticResource WindowBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Grid.Column="0" Background="{StaticResource BaseBrush}">
            <StackPanel>
                <TextBlock x:Name="LogoLabel" Text="DLsite 下载器" FontSize="17" FontWeight="Bold"
                           Margin="20,22,12,18" />
                <RadioButton x:Name="NavSearch" Style="{StaticResource NavButton}" GroupName="nav"
                             IsChecked="True" Checked="Nav_Checked" Tag="search" Content="搜索" />
                <RadioButton x:Name="NavDownload" Style="{StaticResource NavButton}" GroupName="nav"
                             Checked="Nav_Checked" Tag="download" Content="下载" />
                <RadioButton x:Name="NavDownloaded" Style="{StaticResource NavButton}" GroupName="nav"
                             Checked="Nav_Checked" Tag="downloaded" Content="已下载" />
                <RadioButton x:Name="NavMediaLib" Style="{StaticResource NavButton}" GroupName="nav"
                             Checked="Nav_Checked" Tag="medialib" Content="媒体库" />
                <RadioButton x:Name="NavTag" Style="{StaticResource NavButton}" GroupName="nav"
                             Checked="Nav_Checked" Tag="tag" Content="标签" />
                <RadioButton x:Name="NavSetting" Style="{StaticResource NavButton}" GroupName="nav"
                             Checked="Nav_Checked" Tag="setting" Content="设置" />
            </StackPanel>
        </Border>

        <!-- 右侧页面容器 -->
        <ContentControl x:Name="PageHost" Grid.Column="1" Margin="14" />
    </Grid>
</Window>
